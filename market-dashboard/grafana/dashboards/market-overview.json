          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT CASE WHEN asset_key IN ('SPX','NDX','DJI','CAN') THEN 'North America' WHEN asset_key IN ('UKX','DAX','CAC') THEN 'Europe' WHEN asset_key IN ('NKY','HKG','CHN','IND','KOR','TWN','AUS') THEN 'Asia-Pacific' WHEN asset_key IN ('BRA') THEN 'Latin America' ELSE 'Other' END AS region, asset_name, ROUND(value::numeric, 2) AS value, ROUND(change::numeric, 2) AS change, ROUND(change_percent::numeric, 2) AS change_percent, ts AS last_update FROM market_asset_snapshot WHERE category = 'indices' ORDER BY 1, 2;",
          "refId": "A"
